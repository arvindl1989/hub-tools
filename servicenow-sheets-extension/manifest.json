{
  "manifest_version": 3,
  "name": "ServiceNow → Google Sheets Sync",
  "version": "1.0.0",
  "description": "One-click sync of ServiceNow list views to Google Sheets",
  "permissions": [
    "identity",
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "https://*.service-now.com/*",
    "https://sheets.googleapis.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.service-now.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "ServiceNow → Sheets"
  },
  "oauth2": {
    "client_id": "YOUR_CLIENT_ID.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/spreadsheets"
    ]
  },
  "externally_connectable": {
    "matches": [
      "https://*.netlify.app/*",
      "https://*.railway.app/*",
      "http://localhost/*",
      "https://localhost/*"
    ]
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
